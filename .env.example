# ─── Backend priority: OpenAI → Groq → OpenRouter → Ollama (local) ───────────
# The script uses the first provider whose key is present and valid.

# ─── OpenAI (paid) ───────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# ─── Groq (free cloud — recommended) ─────────────────────────────────────────
# Sign up free at https://console.groq.com → API Keys
# Free tier: ~14,400 requests/day for llama-3.3-70b-versatile
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenRouter (free cloud — many permanently-free models) ──────────────────
# Sign up free at https://openrouter.ai → Keys
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# ─── Ollama / local Llama (CPU — used when no cloud key is set) ──────────────
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ─── Output ──────────────────────────────────────────────────────────────────
# OUTPUT_FORMAT=md          # md (default) or docx
# TARGET_CHAPTERS=11        # 10, 11, or 12

# ─── Development / testing ───────────────────────────────────────────────────
# TEST_RUN=1                # same as --test flag: 2 short chapters
